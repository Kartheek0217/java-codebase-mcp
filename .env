# --- Server Configuration ---
SERVER_PORT=9696
SPRING_APPLICATION_NAME=java-codebase-mcp

# --- Database Configuration (H2) ---
SPRING_DATASOURCE_URL=jdbc:h2:file:./data/mcpdb;DB_CLOSE_DELAY=-1;CACHE_SIZE=131072
SPRING_DATASOURCE_USERNAME=sa
SPRING_DATASOURCE_PASSWORD=

# --- Indexing & Search Configuration ---
LUCENE_RAM_BUFFER_SIZE=128.0
SPRING_THREADS_VIRTUAL_ENABLED=true

# --- Headless Browser Configuration ---
BROWSER_HEADLESS=true
BROWSER_TYPE=chromium
BROWSER_VIEWPORT_WIDTH=1280
BROWSER_VIEWPORT_HEIGHT=720
BROWSER_TIMEOUT_MS=120000
BROWSER_MAX_SESSIONS=10

# --- JVM Startup Configuration ---
# These can be used in a run script: java $JAVA_OPTS -jar your-app.jar
JAVA_OPTS="-Xms512m -Xmx2g -XX:+UseG1GC -XX:+UseStringDeduplication -XX:MaxGCPauseMillis=200 -Dspring.application.admin.enabled=true -Dspring.boot.project.name=java-codebase-mcp"
